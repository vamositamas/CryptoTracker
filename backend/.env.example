# CryptoTracker backend environment variables
# Copy this file to .env and fill in the values.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ── Storage ──────────────────────────────────────────────────────────────────
# Absolute or relative path to the JSON data directory.
# DATA_DIR=./data

# ── Auth ─────────────────────────────────────────────────────────────────────
# Required: secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=24h

# ── At-rest encryption ────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting trader data files (trades, audit log).
# Must be a 64-character lowercase hex string (32 bytes / 256 bits).
#
# Generate a new key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# IMPORTANT:
#   • Keep this value secret — losing it means losing access to all stored data.
#   • Back it up securely before encrypting any data.
#   • Existing plain-JSON files are still readable when the key is set
#     (backward-compatible migration on next write).
#   • Leave unset to disable encryption (plain JSON storage).
#
# DATA_ENCRYPTION_KEY=
